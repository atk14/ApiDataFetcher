{
        "name": "atk14/api-data-fetcher",
        "type": "library",
        "description": "PHP client library for communication with ATK14 RESTful APIs and other JSON APIs",
        "keywords": ["atk14", "api", "restful", "client"],
        "homepage": "https://github.com/atk14/ApiDataFetcher",
        "license": ["MIT"],
        "authors": [
                {
                        "name": "Jaromir Tomek",
                        "homepage": "https://github.com/yarri"
                }
        ],
        "require": {
                "php": ">=5.6.0",
                "atk14/url-fetcher": ">=1.8.3 <2.0",
                "atk14/stop-watch": "0.*",
								"atk14/files": ">=1.5 1.*"
        },
        "require-dev": {
                "atk14/tester": "*",
                "atk14/logger": "*"
        },
        "autoload": {
                "classmap": ["src"]
        }
}
